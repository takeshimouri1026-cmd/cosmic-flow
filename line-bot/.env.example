# ============================================================
# LINE Messaging API 設定
# LINE Developers コンソール → チャネル設定 で確認
# ============================================================
LINE_CHANNEL_SECRET=ここにチャネルシークレットを貼る
LINE_CHANNEL_ACCESS_TOKEN=ここにチャネルアクセストークンを貼る

# ============================================================
# Anthropic API 設定（Cosmic Flow と同じキーでOK）
# ============================================================
ANTHROPIC_API_KEY=ここにAnthropicAPIキーを貼る

# ============================================================
# 家族メンバーのLINE User ID
# → まず空欄でサーバーを起動し、グループで発言してログを見る
#    ログに「未登録のユーザー: U〇〇〇...」と出るのでそれをコピーして貼る
# ============================================================
LINE_USER_TAKEYUKI=
LINE_USER_YORIMI=
LINE_USER_HANA=

# ============================================================
# サーバー設定
# ============================================================
PORT=3002
